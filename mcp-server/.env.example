# LLM provider: "ollama" | "gemini" | "auto" (auto picks gemini if key set, else ollama)
LLM_PROVIDER=auto

# Path to the DuckDB analytics database
TRANSPORT_DB_PATH=data/processed/transport.duckdb

# --- Ollama (local LLM) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:26b-mlx
OLLAMA_TIMEOUT_SECONDS=120

# --- Gemini (Google) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
